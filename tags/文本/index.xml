&lt;span id=&#34;cb3-6&#34;&gt;&lt;a href=&#34;#cb3-6&#34; aria-hidden=&#34;true&#34;&gt;&lt;/a&gt;  &lt;span class=&#34;kw&#34;&gt;&amp;lt;layout&lt;/span&gt;&lt;span class=&#34;ot&#34;&gt; delimiter=&lt;/span&gt;&lt;span class=&#34;st&#34;&gt;&amp;quot;; &amp;quot;&lt;/span&gt;&lt;span class=&#34;kw&#34;&gt;&amp;gt;&lt;/span&gt;&lt;/span&gt;
