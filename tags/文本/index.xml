&lt;span id=&#34;cb3-8&#34;&gt;&lt;a href=&#34;#cb3-8&#34; aria-hidden=&#34;true&#34;&gt;&lt;/a&gt;      &lt;span class=&#34;kw&#34;&gt;&amp;lt;text&lt;/span&gt;&lt;span class=&#34;ot&#34;&gt; macro=&lt;/span&gt;&lt;span class=&#34;st&#34;&gt;&amp;quot;author-intext&amp;quot;&lt;/span&gt;&lt;span class=&#34;kw&#34;&gt;/&amp;gt;&lt;/span&gt;&lt;/span&gt;
